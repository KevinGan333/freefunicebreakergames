{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; frame-src 'self'; connect-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self';"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/topics/topics/first-day-of-class-icebreakers.html",
      "destination": "/topics/first-day-of-class-icebreakers.html",
      "permanent": true
    },
    {
      "source": "/templates/questions/classroom-icebreaker-questions.html",
      "destination": "/questions/classroom-icebreaker-questions.html",
      "permanent": true
    }
  ]
}
